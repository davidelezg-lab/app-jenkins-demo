pipeline {
    agent any

    stages {
        stage('Install') {
            steps {
                bat 'echo Instalando dependencias'
            }
        }

        stage('Test') {
            steps {
                bat 'echo Ejecutando tests'
            }
        }

        stage('Build') {
            steps {
                bat 'echo Build completado'
            }
        }
    }
}
